NEXT_PUBLIC_SITE_URL=https://www.thenicepicnic.com

# Base de données (Vercel Postgres / Neon) — obligatoire en production
POSTGRES_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require
# DATABASE_URL=  # alias accepté si déjà configuré sur Vercel

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRODUCT_ID_MEDIUM=prod_xxx
STRIPE_PRODUCT_ID_PRESTIGE=prod_xxx
STRIPE_PRODUCT_ID_WELLNESS=prod_xxx
STRIPE_PRODUCT_ID_FLOATING=prod_xxx
STRIPE_PRODUCT_ID_ROMANTIC_UPSELL=prod_xxx

# Admin Julien
ADMIN_EMAIL=hello@thenicepicnic.com
ADMIN_PASSWORD=change-me-strong-password
ADMIN_SESSION_SECRET=random-long-secret-string
ADMIN_DASHBOARD_KEY=optional-legacy-url-key

# Emails (Resend) — notification à chaque réservation confirmée
RESEND_API_KEY=re_xxx
RESERVATION_NOTIFY_EMAIL=hello@thenicepicnic.com
RESERVATION_FROM_EMAIL=The Nice Picnic <reservations@thenicepicnic.com>

# GetYourGuide — connectivité fournisseur (à compléter avec GYG)
GYG_INTEGRATION_ENABLED=true
GYG_PRODUCT_ID=medium
GYG_SUPPLIER_ID=thenicepicnic
GYG_API_USERNAME=
GYG_API_PASSWORD=
GYG_API_TOKEN=
GYG_NOTIFY_AVAILABILITY_URL=
GYG_BOOKING_CUTOFF_HOURS=24
# Dev uniquement : GYG_SKIP_AUTH=true

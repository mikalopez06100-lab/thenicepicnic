NEXT_PUBLIC_SITE_URL=https://www.thenicepicnic.com

# Base de données (Vercel Postgres / Neon) — obligatoire en production
POSTGRES_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require
# DATABASE_URL=  # alias accepté si déjà configuré sur Vercel

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRODUCT_ID_MEDIUM=prod_xxx
STRIPE_PRODUCT_ID_PRESTIGE=prod_xxx
STRIPE_PRODUCT_ID_WELLNESS=prod_UlNybnBDSmRJnc
STRIPE_PRODUCT_ID_FLOATING=prod_UlO1PpOj7a4ji9
STRIPE_PRODUCT_ID_ROMANTIC_UPSELL=prod_xxx

# Admin Julien
ADMIN_EMAIL=hello@thenicepicnic.com
ADMIN_PASSWORD=change-me-strong-password
ADMIN_SESSION_SECRET=random-long-secret-string
ADMIN_DASHBOARD_KEY=optional-legacy-url-key

# Emails (Resend) — notification à chaque réservation confirmée
RESEND_API_KEY=re_xxx
RESERVATION_NOTIFY_EMAIL=hello@thenicepicnic.com
RESERVATION_FROM_EMAIL=The Nice Picnic <reservations@thenicepicnic.com>

# GetYourGuide — API fournisseur (GYG appelle votre site)
# Doc fournisseur : https://integrator.getyourguide.com/documentation/supplier_endpoints
# Notify GYG     : https://integrator.getyourguide.com/documentation/gyg_endpoints
# Note : code.getyourguide.com/partner-api-spec = Partner API (vendre des activités GYG), pas cette intégration.
GYG_INTEGRATION_ENABLED=true
GYG_PRODUCT_ID=medium
GYG_SUPPLIER_ID=thenicepicnic
GYG_API_USERNAME=
GYG_API_PASSWORD=
GYG_API_TOKEN=
# Outbound notify (TNP → GYG) — défaut prod : https://api.getyourguide.com/1/notify-availability-update
# Test : GYG_ENV=test ou GYG_API_BASE_URL=https://api.gygtest.net
GYG_API_BASE_URL=
GYG_NOTIFY_AVAILABILITY_URL=
GYG_NOTIFY_ENABLED=true
GYG_BOOKING_CUTOFF_HOURS=24
# Dev uniquement : GYG_SKIP_AUTH=true

# Google Business / SEO
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_SITE_VERIFICATION=
